APP_ENV=production
APP_VERSION=0.1.0
LOG_LEVEL=INFO
FRONTEND_URL=https://your-gcp-project-id.web.app
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Store this whole value in Secret Manager as sevasetu-database-url.
# Cloud Run connects to Cloud SQL through /cloudsql when --add-cloudsql-instances is set.
DATABASE_URL=postgresql+asyncpg://postgres:REPLACE_WITH_PASSWORD@/sevasetu?host=/cloudsql/PROJECT_ID:asia-south1:sevasetu-postgres

# Store these in Secret Manager, never in source.
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_API_KEY

# Leave unset unless the frontend sends Firebase ID tokens.
# If set, mutating routes require Authorization: Bearer <Firebase ID token>.
FIREBASE_CREDENTIALS_PATH=
FIREBASE_DEV_BYPASS=false
